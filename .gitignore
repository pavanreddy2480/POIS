# =============================================================================
# Minicrypt Clique Explorer — .gitignore
# Python backend + React/Vite frontend + macOS
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
.eggs/
sdist/
wheels/
pip-wheel-metadata/
MANIFEST
design/

# Virtual environments
.venv/
venv/
env/
ENV/
.env
.env.*

# -----------------------------------------------------------------------------
# FastAPI / Uvicorn
# -----------------------------------------------------------------------------
*.log
uvicorn.log

# -----------------------------------------------------------------------------
# Node / Vite  (web/)
# -----------------------------------------------------------------------------
web/node_modules/
web/dist/
web/.vite/
web/*.local

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# -----------------------------------------------------------------------------
# R
# -----------------------------------------------------------------------------
.Rhistory
.RData
.Rproj.user/

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# OS / misc
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.tmp
*.temp
*.bak
*.orig

# -----------------------------------------------------------------------------
# Secrets — never commit these
# -----------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs/viva-questions.md
